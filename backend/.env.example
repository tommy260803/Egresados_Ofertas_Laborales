# # Database
# DB_HOST=postgres
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=egresados_db

# # JWT
# JWT_SECRET=supersecretkey
# JWT_REFRESH_SECRET=refreshsecretkey
# JWT_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d

# # Redis (BullMQ)
# REDIS_HOST=redis
# REDIS_PORT=6379

# # Email (ejemplo con nodemailer, opcional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=user@gmail.com
# SMTP_PASS=app_password

# # Frontend URL
# FRONTEND_URL=http://localhost:3000
# ============================================
# Base de datos PostgreSQL
# ============================================
DB_HOST=postgres               # Host de la BD (en local: localhost)
DB_PORT=5432                   # Puerto de PostgreSQL
DB_USER=postgres               # Usuario de la BD
DB_PASSWORD=postgres            # Contraseña (cambiar en producción)
DB_NAME=egresados_db           # Nombre de la base de datos

# ============================================
# JWT (Autenticación)
# ============================================
JWT_SECRET=supersecretkeyjwt   # Clave para firmar access token (cambiar)
JWT_REFRESH_SECRET=refreshsecretkey # Clave para refresh token
JWT_EXPIRES_IN=15m             # Duración access token
JWT_REFRESH_EXPIRES_IN=7d      # Duración refresh token

# ============================================
# Redis (BullMQ colas)
# ============================================
REDIS_HOST=redis               # En local: localhost
REDIS_PORT=6379

# ============================================
# Frontend URL (CORS)
# ============================================
FRONTEND_URL=http://localhost:3000   # En producción, dominio real

# ============================================
# SMTP (Notificaciones por correo)
# ============================================
SMTP_HOST=smtp.gmail.com       # Servidor SMTP
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_contraseña_app     # Usar contraseña de aplicación

# ============================================
# Entorno
# ============================================
NODE_ENV=development            # production para despliegue
PORT=4000                       # Puerto del backend

# ============================================
# Opcional: Para Railway/Vercel
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:4000  # URL pública del backend