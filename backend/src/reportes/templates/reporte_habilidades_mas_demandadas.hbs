<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <title>{{titulo}}</title>
  <style>
    @page {
      margin: 1.5cm;
    }
    body {
      font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      color: #1F2937;
      line-height: 1.5;
      margin: 0;
      padding: 0;
      background-color: #ffffff;
    }
    .header {
      border-bottom: 2px solid #1E3A8A;
      padding-bottom: 15px;
      margin-bottom: 20px;
      display: table;
      width: 100%;
    }
    .header-left {
      display: table-cell;
      vertical-align: bottom;
    }
    .header-right {
      display: table-cell;
      vertical-align: bottom;
      text-align: right;
      font-size: 10px;
      color: #6B7280;
    }
    .system-label {
      color: #1E3A8A;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      margin: 0;
    }
    h1 {
      color: #111827;
      font-size: 24px;
      margin: 2px 0 0 0;
      font-weight: 800;
    }
    .report-meta {
      background-color: #F9FAFB;
      border: 1px solid #E5E7EB;
      border-radius: 4px;
      padding: 10px 15px;
      margin-bottom: 20px;
      font-size: 11px;
    }
    .meta-grid {
      display: table;
      width: 100%;
    }
    .meta-item {
      display: table-cell;
    }
    .meta-label {
      font-weight: 700;
      color: #4B5563;
      margin-right: 5px;
    }
    table.data-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 20px;
    }
    table.data-table th {
      background-color: #F3F4F6;
      color: #374151;
      font-weight: 700;
      text-align: left;
      padding: 10px;
      font-size: 11px;
      border-bottom: 2px solid #E5E7EB;
      text-transform: uppercase;
    }
    table.data-table td {
      padding: 8px 10px;
      font-size: 11px;
      border-bottom: 1px solid #E5E7EB;
      color: #4B5563;
    }
    table.data-table tr:nth-child(even) {
      background-color: #F9FAFB;
    }
    .no-data {
      text-align: center;
      padding: 40px;
      background-color: #F9FAFB;
      border: 1px dashed #D1D5DB;
      border-radius: 4px;
      color: #6B7280;
      font-size: 13px;
    }
    .footer {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      text-align: center;
      font-size: 9px;
      color: #9CA3AF;
      border-top: 1px solid #E5E7EB;
      padding-top: 5px;
    }
    .count-badge {
      display: inline-block;
      padding: 2px 8px;
      background-color: #EEF2FF;
      color: #1E40AF;
      border-radius: 4px;
      font-weight: 700;
    }
  </style>
</head>
<body>
  <div class="header">
    <div class="header-left">
      <p class="system-label">Análisis de Mercado</p>
      <h1>{{titulo}}</h1>
    </div>
    <div class="header-right">
      <div>Generado: {{generatedAt}}</div>
      <div>Reporte Administrativo</div>
    </div>
  </div>

  <div class="report-meta">
    <div class="meta-grid">
      <div class="meta-item"><span class="meta-label">Rango:</span> {{filtros.fechaDesde}} - {{filtros.fechaHasta}}</div>
      <div class="meta-item"><span class="meta-label">Sector:</span> {{filtros.sector}}</div>
    </div>
  </div>

  {{#if rows.length}}
    <table class="data-table">
      <thead>
        <tr>
          <th>Habilidad</th>
          <th style="text-align: center; width: 150px;">N° Ofertas</th>
        </tr>
      </thead>
      <tbody>
        {{#each rows}}
        <tr>
          <td><strong>{{this.habilidad}}</strong></td>
          <td style="text-align: center;">
            <span class="count-badge">{{this.cantidad_ofertas}}</span>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  {{else}}
    <div class="no-data">
      No hay datos disponibles para generar el análisis de habilidades.
    </div>
  {{/if}}

  <div class="footer">
    Sistema de Seguimiento de Egresados &copy; 2024 | Análisis de Habilidades
  </div>
</body>
</html>
