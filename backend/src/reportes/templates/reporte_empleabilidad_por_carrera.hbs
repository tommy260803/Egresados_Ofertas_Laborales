<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <title>{{titulo}}</title>
  <style>
    body { font-family: Arial, sans-serif; font-size: 12px; color: #111827; }
    h1 { font-size: 18px; margin-bottom: 6px; }
    .meta { margin-bottom: 12px; color: #4b5563; }
    table { width: 100%; border-collapse: collapse; }
    th, td { border: 1px solid #d1d5db; padding: 6px; text-align: left; }
    th { background: #f3f4f6; }
  </style>
</head>
<body>
  <h1>{{titulo}}</h1>
  <div class="meta">
    <div>Generado: {{generatedAt}}</div>
    <div>Desde: {{filtros.fechaDesde}} | Hasta: {{filtros.fechaHasta}}</div>
    <div>Carrera: {{filtros.carrera}} | Sector: {{filtros.sector}}</div>
  </div>
  <table>
    <thead>
      <tr>
        <th>Carrera</th>
        <th>Total egresados</th>
        <th>Contratados</th>
        <th>Tasa</th>
      </tr>
    </thead>
    <tbody>
      {{#each rows}}
      <tr>
        <td>{{this.carrera}}</td>
        <td>{{this.total_egresados}}</td>
        <td>{{this.contratados}}</td>
        <td>{{this.tasa}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</body>
</html>
